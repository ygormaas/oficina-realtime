# ── Segredos: NUNCA versionar ────────────────────────────────
# O .env guarda caminhos de credencial e parâmetros do ambiente
backend/.env
.env
# Chaves de service account / tokens do Google
*service-account*.json
*credentials*.json
*.key.json

# ── Dados operacionais (exports das views) ──────────────────
# Contêm ordens, veículos e usuários — ficam só na sua máquina
backend/dados/*.csv

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Runtime portatil e credenciais (NAO versionar) ──────────
# Python embutido (~95 MB) gerado localmente; recriavel.
runtime/
# Pasta com a chave da service account que viaja com o pacote.
credenciais/

# ── Diversos ─────────────────────────────────────────────────
.DS_Store
*.log

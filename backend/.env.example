# Copie este arquivo para ".env" e ajuste.

# --- Fonte de dados ---
#   mock      -> dados de demonstração (sem BigQuery, sem arquivos)
#   csv       -> lê backend/dados/STJ.csv e STJ_Manutencao.csv (validação offline)
#   bigquery  -> produção
DATA_SOURCE=csv

# --- BigQuery (usado quando DATA_SOURCE=bigquery) ---
BQ_PROJECT=gcp-maas-proj-manutencao
BQ_DATASET=silver
BQ_VIEW_MANUTENCAO=STJ_Manutencao
BQ_VIEW_STJ=STJ
BQ_MAX_ROWS=50000

# Autenticação (escolha UMA):
#   a) rode uma vez:  gcloud auth application-default login
#   b) ou aponte para o JSON de uma service account com papel "BigQuery Data Viewer":
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# --- Ciclo de atualização (segundos). 300 = 5 min ---
POLL_SECONDS=300

# --- Regras ajustáveis ---
# "Preventivas atrasadas": ignora janelas vencidas há mais de N dias.
# A base tem 1.081 preventivas de planos antigos vencidas em 2024; com 90
# dias esse ruído fica de fora. Aumente para enxergar o backlog inteiro.
PREV_RETRO_DIAS=90

# --- KPIs sem coluna nas views atuais (entram manualmente por enquanto) ---
KPI_SS_AGUARDANDO_MANUAL=0
KPI_QUALIDADE_MANUAL=0
KPI_CLIENTES_ESP_MANUAL=0
KPI_RESERVA_LIMITE_MANUAL=0
# Retorno: 0 = regra automática (XRETORN preenchido); >0 força o valor
KPI_RETORNO_MANUAL=0

# --- Efetivo de mecânicos (Capacidade × demanda) ---
MECANICOS_TRABALHANDO=11
MECANICOS_DISPONIVEL=6
MECANICOS_PAUSA=0

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
